# app/decorators/decidim/assembly_cells_helper_decorator.rb
# frozen_string_literal: true

# Decorador para las celdas que muestran asambleas
module Decidim::AssemblyCellsHelperOverride
  def assembly_title
    if assembly.respond_to?(:contextual_name)
      "#{assembly.contextual_name}: #{assembly.title}"
    else
      assembly.title
    end
  end
  
  def assembly_type_badge
    if assembly.respond_to?(:contextual_name)
      content_tag(:span, assembly.contextual_name, class: "badge")
    end
  end
end

# Aplicamos el decorador a las celdas relevantes
if defined?(Decidim::Assemblies::AssemblyMCell)
  Decidim::Assemblies::AssemblyMCell.include(Decidim::AssemblyCellsHelperOverride)
end

if defined?(Decidim::Assemblies::AssemblyGCell)
  Decidim::Assemblies::AssemblyGCell.include(Decidim::AssemblyCellsHelperOverride)
end