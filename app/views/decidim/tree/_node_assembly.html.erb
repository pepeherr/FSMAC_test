<!-- app/views/decidim/tree/_node_assembly.html.erb -->

<li class="tree-view__item">

  <%# Detectar si hay hijos %>
  <% hijas = @asambleas.select { |a| a.parent_id == nodo.id } %>
  <% tiene_hijos = hijas.any? || 
                   @comps_assembly[nodo.id]&.any? || 
                   @procesos_por_asamblea[nodo.id]&.any? %>

  <!-- CABECERA -->
  <div class="tree-node">

    <% if tiene_hijos %>
      <button class="tree-toggle" data-target="assembly-<%= nodo.id %>">
        <%= nivel == 0 ? "▾" : "▸" %>
      </button>
    <% else %>
      <span class="tree-toggle-placeholder"></span>
    <% end %>

    <%= d_icon "assembly", css: "text-muted" %>

    <%= link_to titulo_objeto(nodo), enlace_objeto(nodo), class: "link font-semibold" %>

    <% if @mostrar_id %>
      <span class="text-muted small">(ID: <%= nodo.id %>)</span>
    <% end %>
  </div>

  <!-- HIJOS -->
  <% if tiene_hijos %>
    <div id="assembly-<%= nodo.id %>" 
     class="tree-children <%= nivel == 0 ? '' : 'is-collapsed' %>">

      <!-- COMPONENTES -->
      <% if @comps_assembly[nodo.id]&.any? %>
        <div class="tree-section">
          <div class="tree-section__title">
            <%= d_icon "component", css: "text-muted" %>
            <%= t("decidim.tree.index.components") %>
          </div>

          <ul class="tree-sublist">
            <% @comps_assembly[nodo.id].each do |comp| %>
              <li class="tree-sublist__item">
                <%= d_icon "component", css: "text-muted" %>

                <%= link_to comp.name[@locale.to_s] || comp.name['es'] || comp.manifest_name,
                            enlace_objeto(comp),
                            class: "link" %>

                <% if @mostrar_id %>
                  <span class="text-muted small">
                    (<%= comp.manifest_name %>, ID: <%= comp.id %>)
                  </span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- PROCESOS -->
      <% if @procesos_por_asamblea[nodo.id]&.any? %>
        <div class="tree-section">
          <div class="tree-section__title">
            <%= d_icon "process", css: "text-muted" %>
            <%= t("decidim.menu.processes") %>
          </div>

          <ul class="tree-sublist">
            <% @procesos_por_asamblea[nodo.id].each do |proceso| %>
              <li class="tree-sublist__item">

                <% tiene_hijos_proceso = @comps_process[proceso.id]&.any? %>

                <div class="tree-node">

                  <% if tiene_hijos_proceso %>
                    <button class="tree-toggle" data-target="process-<%= proceso.id %>">▸</button>
                  <% else %>
                    <span class="tree-toggle-placeholder"></span>
                  <% end %>

                  <%= d_icon "process", css: "text-muted" %>

                  <%= link_to titulo_objeto(proceso), enlace_objeto(proceso), class: "link" %>

                  <% if @mostrar_id %>
                    <span class="text-muted small">(ID: <%= proceso.id %>)</span>
                  <% end %>
                </div>

                <% if tiene_hijos_proceso %>
                  <div id="process-<%= proceso.id %>" class="tree-children is-collapsed">

                    <ul class="tree-sublist">

                      <% @comps_process[proceso.id]&.each do |comp_proc| %>
                        <% if mostrar_componente_proposals?(comp_proc.id) %>
                          <%= render partial: "decidim/tree/component_node",
                                     locals: { comp_proc: comp_proc } %>
                        <% end %>
                      <% end %>
                    </ul>

                  </div>
                <% end %>

              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- ASAMBLEAS HIJAS -->
      <% if hijas.any? %>
        <ul class="tree-view__children">
          <% hijas.each do |hija| %>
            <%= render partial: "decidim/tree/node_assembly",
                       locals: { nodo: hija, 
                                 nivel: (nivel || 0) + 1 
                                } %>
          <% end %>
        </ul>
      <% end %>

    </div>
  <% end %>

</li>