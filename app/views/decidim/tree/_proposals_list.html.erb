<!-- app/views/decidim/tree/_proposals_list.html.erb -->

<%
   # Recibir variables locales
   proposals_list = local_assigns[:proposals] || []
   madre_id = local_assigns[:madre_id]
   nivel = local_assigns[:nivel] || 0
   
   # Definir hijas FILTRANDO por madre_id
   hijas = proposals_list.select { |p| p.parent_objective_id == madre_id }
%>

<% if hijas.any? %>
  <ul style="list-style: none; padding-left: <%= nivel * 20 %>px; margin-top: 5px; 
             border-left: <%= nivel > 0 ? '1px dashed #aaa' : 'none' %>;">
    <% hijas.each do |hija| %>
      <li style="margin: 8px 0;">
        <div style="display: flex; align-items: flex-start;">
          <span style="margin-right: 5px; color: #666; min-width: 20px;">
            <%= "└─" if nivel > 0 %>
          </span>
          <span role="img" aria-label="Propuesta" style="margin-right: 5px;">📄</span>
          <div>
            <%= link_to titulo_objeto(hija), enlace_objeto(hija), 
                        style: "text-decoration: none; color: #2c3e50; font-weight: #{nivel == 1 ? 'bold' : 'normal'};" %>
            <small style="margin-left: 5px; color: #999;">
              (ID: <%= hija.id %><%= ", Padre: #{hija.parent_objective_id}" if hija.parent_objective_id %>)
            </small>
            
            <%# Renderizar hijas de esta propuesta recursivamente %>
            <% hijas_de_hija = proposals_list.select { |p| p.parent_objective_id == hija.id } %>
            <% if hijas_de_hija.any? %>
              <%= render partial: "decidim/tree/proposals_list", 
                         locals: { 
                           proposals: proposals_list,
                           madre_id: hija.id,
                           nivel: nivel + 1
                         } %>
            <% end %>
          </div>
        </div>
      </li>
    <% end %>
  </ul>
<% end %>