        process_steps: Fases del conflicto
    participatory_processes:
      admin:
        content_blocks:
          democratic_quality_stats_settings_form:
            citizen_influence:
              citizen_decisional_intervention:
                legend: 'De todas las fases del conflicto (desde la selección de las propuestas hasta el seguimiento de su ejecución) ¿en cuántas ha tenido la ciudadanía la capacidad de tomar decisiones o emprender acciones ejecutivas?'
              citizen_influence_level:
                legend: '¿Hasta qué punto la ciudadanía tiene autoridad decisoria en este conflicto, desde la simple recepción de información hasta la influencia decisiva en las decisiones y en la gestión de recursos?'
            inclusiveness:
              functional_diversity_invited:
                legend: '¿Cómo se evalúa el grado de diversidad de agentes y participantes con respecto a la población de referencia en el conflicto?'
              languages_communicated:
                legend: '¿Cuántos idiomas se han utilizado en el conflicto?'
            informativeness:
              information_provided:
                legend: '¿Se ha facilitado información a las participantes sobre cuál era su capacidad de influencia en el tema que se debatía? (tanto en la comunicación del conflicto y las invitaciones, como al inicio de cada sesión de debate)'
        participatory_process_duplicates:
          form:
            slug_help_html: 'Los segmentos de URL se utilizan para generar las URLs que apuntan a este conflicto. Solo acepta letras, números y guiones, y debe comenzar con una letra. Ejemplo: %{url}'
        participatory_process_groups:
          form:
            title: Acerca de este conflicto
        participatory_process_imports:
          form:
            slug_help_html: 'Los textos cortos de URL se utilizan para generar las URL que apuntan a este conflicto. Sólo acepta letras, números y guiones, y debe comenzar con una letra. Ejemplo: %{url}'
        participatory_processes:
          form:
            announcement_help: El texto que ingreses aquí se mostrará a la participante justo debajo de la información del conflicto.
            related_processes: conflictos relacionados
            select_process_group: Selecciona un grupo de conflictos
      content_blocks:
        democratic_quality_stats:
          automatic_metrics:
            indicators:
              hybridization_tooltip: Este indicador mide el nivel de combinación entre espacios presenciales y digitales durante el conflicto
              influence_tooltip: Este indicador mide el nivel de influencia ciudadana en las propuestas aceptadas y los resultados del conflicto.
              traceability_tooltip: Este indicador mide la transparencia y trazabilidad del conflicto participativo. Refleja con qué facilidad la ciudadanía pueden seguir la evolución de las propuestas y verificar las acciones institucionales a través de los registros publicados.
          global_score:
            description_html: 'A continuación se muestra un conjunto de indicadores utilizados para evaluar la calidad democrática de este conflicto participativo. Para más detalles sobre cómo se calculan, consulta la página <a href="%{info_url}">de información sobre los indicadores de calidad democrática</a>.'
          qualitative_metrics:
            description: Estos indicadores se obtienen de las respuestas a una encuesta de autoevaluación realizada por las responsables del conflicto participativo.
            indicators:
              informativeness_tooltip: Mide el nivel de claridad y la información proporcionada dentro del conflicto.
        highlighted_processes:
          name: conflictos destacados
        related_processes:
          name: conflictos relacionados
