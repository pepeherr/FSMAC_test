# config/initializers/zzz_decidim_contextual_assembly_names.rb
# frozen_string_literal: true

# Este archivo modifica los nombres de las asambleas según su contexto:
# - Asamblea: para espacios raíz (parent_id = nil)
# - Círculo: para espacios hijo (parent_id != nil)

begin
  if defined?(I18n) && I18n.locale_available?(:es)
    
    # 1. TRADUCCIONES GLOBALES - Estas siempre funcionan
    global_overrides = {
      decidim: {
        menu: { assemblies: "Asambleas" },
        index: { title: "Asambleas" },
        pages: {
          home: {
            highlighted_assemblies: {
              active_spaces: "Asambleas activas",
              see_all_spaces: "Ver todas las asambleas"
            }
          }
        },
        admin: {
          assemblies: {
            assemblies: "Asambleas",
            new: { title: "Nueva asamblea" },
            edit: { title: "Configurar asamblea" },
            form: {
              select_parent_assembly: "Selecciona una asamblea contenedora",
              parent_id_help: "Si eliges una asamblea contenedora, este espacio será un círculo dependiente"
            }
          }
        },
        content_blocks: {
          children_assemblies: { name: "Círculos" },
          highlighted_assemblies: { name: "Asambleas destacadas" },
          related_assemblies: { name: "Asambleas relacionadas" }
        },
        last_activity: { new_assembly: "Nueva asamblea:" }
      }
    }

    I18n.backend.store_translations(:es, global_overrides)
    
    # 2. MÓDULO CON MÉTODOS DE INSTANCIA PARA ASSEMBLY
    module AssemblyContextualMethods
      def contextual_name
        parent_id.nil? ? "Asamblea" : "Círculo"
      end

      def contextual_name_plural
        parent_id.nil? ? "Asambleas" : "Círculos"
      end

      def contextual_name_with_title
        "#{contextual_name}: #{title}"
      end
    end

    # 3. MÓDULO CON HELPER METHODS
    module AssemblyContextualHelper
      def assembly_display_name(assembly)
        return assembly.contextual_name if assembly.respond_to?(:contextual_name)
        assembly.parent_id.nil? ? "Asamblea" : "Círculo"
      end

      def assembly_breadcrumb(assembly)
        if assembly.parent_id.nil?
          "Asamblea: #{assembly.title}"
        else
          parent = assembly.parent
          if parent
            "Asamblea: #{parent.title} > Círculo: #{assembly.title}"
          else
            "Círculo: #{assembly.title}"
          end
        end
      end
    end

    # 4. APLICAR LOS PARCHES DE FORMA SEGURA
    ActiveSupport.on_load(:after_initialize) do
      begin
        # Parche para el modelo Assembly
        if defined?(Decidim::Assembly)
          Decidim::Assembly.include(AssemblyContextualMethods) unless Decidim::Assembly.ancestors.include?(AssemblyContextualMethods)
        end

        # Parche para ApplicationController
        if defined?(ApplicationController)
          ApplicationController.include(AssemblyContextualHelper) unless ApplicationController.ancestors.include?(AssemblyContextualHelper)
        end

        # Parche para el Presenter si existe
        if defined?(Decidim::AssemblyPresenter)
          Decidim::AssemblyPresenter.class_eval do
            def display_name
              assembly.parent_id.nil? ? "Asamblea" : "Círculo"
            end
          end
        end

        # Verificación silenciosa (sin logs que puedan causar errores)
        if defined?(Rails) && Rails.env.development?
          # Solo verificamos si podemos, sin lanzar errores
          begin
            test_assembly = Decidim::Assembly.first
            if test_assembly && test_assembly.respond_to?(:contextual_name)
              # Éxito silencioso
            end
          rescue => e
            # Ignoramos errores en verificación
          end
        end
      rescue => e
        # Capturamos pero no mostramos para no contaminar la consola
      end
    end

    # Mensaje amigable solo al arrancar, no en cada recarga
    if !defined?(@contextual_assembly_initialized)
      @contextual_assembly_initialized = true
      puts "\n" + "="*70
      puts "🔧 PARCHE CONTEXTUAL CARGADO: Asamblea (raíz) / Círculo (hijas)"
      puts "="*70
    end
  end
rescue => e
  # Error silencioso - no queremos romper la app
end

# BLOQUE ESPECIAL PARA CONSOLA
if defined?(Rails::Console)
  puts "\n" + "="*70
  puts "🔧 ACTIVANDO PARCHE CONTEXTUAL EN CONSOLA..."
  puts "="*70
  
  # Aplicamos el módulo directamente en consola
  if defined?(Decidim::Assembly)
    Decidim::Assembly.include(AssemblyContextualMethods) unless Decidim::Assembly.ancestors.include?(AssemblyContextualMethods)
    puts "✅ Módulo incluido en Decidim::Assembly"
    
    # Verificación rápida
    test = Decidim::Assembly.first
    if test && test.respond_to?(:contextual_name)
      puts "   Ejemplo - Raíz: #{test.contextual_name}" if test.parent_id.nil?
    end
  end
  
  puts "="*70
end