{
  // ============================================
  // RUBY BASE
  // ============================================
  "ruby.useBundler": true,
  "ruby.useLanguageServer": true,

  "ruby.lint": {
    "rubocop": { "useBundler": true },
    "reek": { "useBundler": true }
  },

  "ruby.format": "rubocop",

  // ============================================
  // RUBOCOP
  // ============================================
  "rubocop.mode": "enableViaGemfile",
  "rubocop.autocorrect": true,

  // ============================================
  // SOLARGRAPH
  // ============================================
  "solargraph.useBundler": true,
  "solargraph.diagnostics": true,
  "solargraph.formatting": false,
  "solargraph.autoformat": false,

  "solargraph.diagnostics.exclude": [
    "**/*.erb",
    "**/*.html.erb"
  ],

  "files.associations": {
  "*.html.erb": "erb"
  },

  // ============================================
  // ERB-LINT 
  // ============================================
  "erb.erb-linter.enable": true,
  "erb.erb-linter.useBundler": true,
  "erb.erb-linter.cmd": "bundle exec erb_lint",
  "erb.erb-linter.onSave": true,

  // ============================================
  // EDITORES POR LENGUAJE
  // ============================================
  "[ruby]": {
    "editor.defaultFormatter": "rubocop.vscode-rubocop",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  "[erb]": {
    "editor.formatOnSave": false,
    "editor.tabSize": 2
  },

  "[html.erb]": {
    "editor.formatOnSave": false,
    "editor.tabSize": 2
  },

  // ============================================
  // GLOBAL
  // ============================================
  "editor.defaultFormatter": null,
  "editor.formatOnSave": false,

  // ============================================
  // EMMET
  // ============================================
  "emmet.includeLanguages": {
    "erb": "html",
    "html.erb": "html"
  },

  // ============================================
  // UI
  // ============================================
  "problems.decorations.enabled": true,
  "editor.renderValidationDecorations": true
}